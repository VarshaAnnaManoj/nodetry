# Build stage
FROM node:22 AS build
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build


# Production stage
FROM nginx:alpine
# Copy custom nginx config  ← IMPORTANT
COPY nginx.conf /etc/nginx/conf.d/default.conf
# Copy built frontend files
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
